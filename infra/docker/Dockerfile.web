FROM node:22-alpine AS base
RUN corepack enable
WORKDIR /app

FROM base AS deps
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY packages ./packages
COPY apps/web ./apps/web
RUN pnpm install --frozen-lockfile || pnpm install
RUN pnpm --filter @softmusic/types build
RUN pnpm --filter @softmusic/shared build
RUN pnpm --filter @softmusic/sdk build
ARG VITE_API_URL=http://localhost:8080
ARG VITE_PWA_ENABLED=true
ARG VITE_APP_VERSION=
ENV VITE_API_URL=$VITE_API_URL
ENV VITE_PWA_ENABLED=$VITE_PWA_ENABLED
ENV VITE_APP_VERSION=$VITE_APP_VERSION
RUN pnpm --filter @softmusic/web build

FROM deps AS runner
RUN apk add --no-cache nginx
COPY infra/nginx/conf.d/spa.conf /etc/nginx/http.d/default.conf
RUN mkdir -p /usr/share/nginx/html \
  && cp -r /app/apps/web/build/client/. /usr/share/nginx/html/
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
