# =============================================================================
# SoftMusic — Variáveis de ambiente (desenvolvimento local)
# Copie para .env: cp infra/docker/.env.example infra/docker/.env
# Documentação: docs/producao/variaveis-ambiente.md
# =============================================================================

# Global
NODE_ENV=development
SOFTMUSIC_ENV=local
LOG_LEVEL=debug
LOG_FORMAT=pretty

# MySQL
MYSQL_ROOT_PASSWORD=root_dev_only
MYSQL_DATABASE=softmusic
MYSQL_USER=softmusic
MYSQL_PASSWORD=softmusic_dev
MYSQL_PORT=3306

# Redis
REDIS_PASSWORD=
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_USER=softmusic
RABBITMQ_PASSWORD=softmusic_dev
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672

# Connection strings (usadas pelos apps via Docker network)
DATABASE_URL=mysql+aiomysql://softmusic:softmusic_dev@mysql:3306/softmusic
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=amqp://softmusic:softmusic_dev@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://redis:6379/1

# API (BFF)
API_PORT=8080
WEB_PORT=5173
API_BASE_URL=http://localhost:8080
WEB_ORIGIN=http://localhost:5173
JWT_ALGORITHM=HS256
JWT_PRIVATE_KEY=dev-only-change-in-production-min-32-chars-long
JWT_PUBLIC_KEY=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
UPLOAD_MAX_SIZE_MB=100

# Python AI
PYTHON_AI_PORT=8000
STORAGE_PROVIDER=local
STORAGE_BUCKET=softmusic-uploads
CELERY_CONCURRENCY=1
ANALYSIS_JSON_VERSION=1.0.0
DEMUCS_ENABLED=true
DEMUCS_MODEL=htdemucs
CUDA_VISIBLE_DEVICES=0
DOCKER_GPUS=all
NVIDIA_VISIBLE_DEVICES=all
PYTORCH_IMAGE=pytorch/pytorch:2.5.1-cuda12.4-cudnn9-runtime

# Web (build args)
VITE_API_URL=http://localhost:8080
VITE_APP_NAME=SoftMusic
VITE_PWA_ENABLED=true
VITE_APP_URL=http://localhost:5173
LP_PORT=5180
ADMIN_PORT=5174
ADMIN_ORIGIN=http://localhost:5174

# SaaS / Billing (python-ai)
CPF_PEPPER=dev-cpf-pepper-change-me
ADMIN_JWT_PRIVATE_KEY=dev-admin-change-in-production-min-32-chars
ADMIN_BOOTSTRAP_EMAIL=
ADMIN_BOOTSTRAP_PASSWORD=
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox
ASAAS_WEBHOOK_TOKEN=

# Observability
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_dev_only
GRAFANA_ROOT_URL=http://localhost:3000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
