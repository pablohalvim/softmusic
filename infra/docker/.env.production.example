# SoftMusic — .env de produção (exemplo)
# Copie para Jenkins Credential "softmusic-production-env" (Secret file)
# Nunca commite o arquivo real com senhas.

NODE_ENV=production
SOFTMUSIC_ENV=production
LOG_LEVEL=info

# Domínios
WEB_ORIGIN=https://app.softmusic.com.br
API_BASE_URL=https://app.softmusic.com.br/api
VITE_API_URL=https://app.softmusic.com.br/api
VITE_APP_URL=https://app.softmusic.com.br
LP_ORIGIN=https://softmusic.com.br
ADMIN_ORIGIN=https://admin.softmusic.com.br

# MySQL
MYSQL_ROOT_PASSWORD=SUBSTITUA
MYSQL_DATABASE=softmusic
MYSQL_USER=softmusic
MYSQL_PASSWORD=SUBSTITUA
DATABASE_URL=mysql+aiomysql://softmusic:SUBSTITUA@mysql:3306/softmusic

# Redis / RabbitMQ
REDIS_PASSWORD=SUBSTITUA
REDIS_URL=redis://:SUBSTITUA@redis:6379/0
RABBITMQ_USER=softmusic
RABBITMQ_PASSWORD=SUBSTITUA
CELERY_BROKER_URL=amqp://softmusic:SUBSTITUA@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://:SUBSTITUA@redis:6379/1

# JWT
JWT_ALGORITHM=HS256
JWT_PRIVATE_KEY=SUBSTITUA-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ADMIN_JWT_PRIVATE_KEY=SUBSTITUA-admin-separado
ADMIN_BOOTSTRAP_EMAIL=admin@softmusic.com.br
ADMIN_BOOTSTRAP_PASSWORD=SUBSTITUA-senha-admin-inicial
ADMIN_BOOTSTRAP_NAME=Administrador

# Asaas
ASAAS_API_KEY=SUBSTITUA
ASAAS_ENVIRONMENT=production
ASAAS_WEBHOOK_TOKEN=SUBSTITUA

# E-mail (transacional + marketing)
SMTP_HOST=SUBSTITUA
SMTP_PORT=587
SMTP_USER=SUBSTITUA
SMTP_PASSWORD=SUBSTITUA
EMAIL_FROM=noreply@softmusic.com.br

# Imagens Docker (pipelines atualizam automaticamente)
SOFTMUSIC_API_IMAGE=docker.io/seu-user/softmusic-api:latest
SOFTMUSIC_PYTHON_AI_IMAGE=docker.io/seu-user/softmusic-python-ai:latest
SOFTMUSIC_WEB_IMAGE=docker.io/seu-user/softmusic-web:latest
SOFTMUSIC_LP_IMAGE=docker.io/seu-user/softmusic-lp:latest

# Observabilidade
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=SUBSTITUA
GRAFANA_ROOT_URL=https://grafana.softmusic.com.br

# IA / GPU
CELERY_CONCURRENCY=1
CUDA_VISIBLE_DEVICES=0
DEMUCS_ENABLED=true
