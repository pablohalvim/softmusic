# SoftMusic — .env de produção (REFERÊNCIA)
#
# Em produção este arquivo é GERADO pelo `infra/docker/scripts/render-env.sh`
# a partir das credenciais Jenkins (Secret text) + defaults. Você não precisa
# criá-lo à mão. Este exemplo serve para saber quais chaves existem e para
# deploy manual (sem Jenkins). Nunca commite o arquivo real com senhas.

NODE_ENV=production
SOFTMUSIC_ENV=production
LOG_LEVEL=info

# Domínios
WEB_ORIGIN=https://app.softmusic.com.br
API_BASE_URL=https://app.softmusic.com.br/api
VITE_API_URL=https://app.softmusic.com.br/api
VITE_APP_URL=https://app.softmusic.com.br
LP_ORIGIN=https://softmusic.com.br
ADMIN_ORIGIN=https://admin.softmusic.com.br

# MySQL
MYSQL_ROOT_PASSWORD=s0ft1Mus1C20
MYSQL_DATABASE=softmusic
MYSQL_USER=softmusic
MYSQL_PASSWORD=s0ft1Mus1C20
DATABASE_URL=mysql+aiomysql://softmusic:s0ft1Mus1C20@mysql:3307/softmusic

# Redis / RabbitMQ
REDIS_PASSWORD=s0ft1Mus1C20
REDIS_URL=redis://:s0ft1Mus1C20@redis:6379/0
RABBITMQ_USER=softmusic
RABBITMQ_PASSWORD=s0ft1Mus1C20
CELERY_BROKER_URL=amqp://softmusic:s0ft1Mus1C20@rabbitmq:5672//
CELERY_RESULT_BACKEND=redis://:s0ft1Mus1C20@redis:6379/1

# JWT
JWT_ALGORITHM=HS256
JWT_PRIVATE_KEY=6fafbe27-82cb-4893-bff4-7a22961dad87
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
ADMIN_JWT_PRIVATE_KEY=8ede7d0d-6531-4deb-b4af-cfd2d2562f58
ADMIN_BOOTSTRAP_EMAIL=admin@softmusic.com.br
ADMIN_BOOTSTRAP_PASSWORD=s0ft1Mus1C20
ADMIN_BOOTSTRAP_NAME=Administrador

# Asaas
ASAAS_API_KEY=s0ft1Mus1C20
ASAAS_ENVIRONMENT=production
ASAAS_WEBHOOK_TOKEN=s0ft1Mus1C20

# E-mail (transacional + marketing)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@softmusic.com.br

# Imagens Docker (build LOCAL no daemon do host, sem registry). Cada job marca
# a imagem como :latest; os deploys usam --force-recreate para pegar a nova.
SOFTMUSIC_API_IMAGE=softmusic/api:latest
SOFTMUSIC_PYTHON_AI_IMAGE=softmusic/python-ai:latest
SOFTMUSIC_WEB_IMAGE=softmusic/web:latest
SOFTMUSIC_LP_IMAGE=softmusic/lp:latest
SOFTMUSIC_ADMIN_WEB_IMAGE=softmusic/admin-web:latest

# Observabilidade
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=s0ft1Mus1C20
GRAFANA_ROOT_URL=https://grafana.softmusic.com.br

# IA / GPU
CELERY_CONCURRENCY=1
CUDA_VISIBLE_DEVICES=0
DEMUCS_ENABLED=true
